{
  "appName": "Rural Routes Explorer",
  "baseline": "iOS v30C/v30B lineage",
  "tabs": [
    "Explore",
    "Map",
    "Scan",
    "Rewards",
    "Profile",
    "Admin"
  ],
  "pwaRoutes": [
    {
      "path": "/",
      "component": "AdventureCenter"
    },
    {
      "path": "/adventures/:id",
      "component": "AdventureDetail"
    },
    {
      "path": "/adventures/turtle-trail",
      "component": "TurtleTrailAdventure"
    },
    {
      "path": "/turtles/:id",
      "component": "TurtleDetail"
    },
    {
      "path": "/behind-the-shell",
      "component": "BehindTheShellGallery"
    },
    {
      "path": "/artists",
      "component": "ArtistGallery"
    },
    {
      "path": "/collections/:id",
      "component": "CollectionGrid"
    },
    {
      "path": "/scan",
      "component": "UniversalQRScanner"
    },
    {
      "path": "/profile",
      "component": "Profile"
    },
    {
      "path": "/profile/showcase",
      "component": "ScreenshotShowcase"
    },
    {
      "path": "/admin/assets",
      "component": "AdminAssetManager"
    },
    {
      "path": "/admin/routes",
      "component": "AdminRouteBuilder"
    },
    {
      "path": "/admin/export",
      "component": "AdminExportImport"
    },
    {
      "path": "/admin/settings",
      "component": "AdminDemoSettings"
    }
  ],
